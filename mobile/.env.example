# TwinMe Mobile App — Environment Variables
# Copy to .env and fill in values

# API base URL (no trailing slash)
# For Android emulator: 10.0.2.2 points to host machine's localhost
# For physical device: use your machine's LAN IP (e.g. 192.168.1.100:3004)
EXPO_PUBLIC_API_URL=http://10.0.2.2:3004/api
