# ===========================================
# TwinMe - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Core ---
NODE_ENV=development
PORT=3004
VITE_APP_URL=http://localhost:8086
VITE_API_URL=http://localhost:3004/api

# --- Supabase (PostgreSQL + pgvector) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth ---
JWT_SECRET=generate-a-strong-random-string-min-32-chars
ENCRYPTION_KEY=generate-a-strong-random-string-min-32-chars

# --- AI / LLM ---
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Optional: daily budget cap in USD (default: 10)
# LLM_DAILY_BUDGET_USD=10

# --- Platform Integrations (Active) ---

# Spotify
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Google (Calendar + YouTube)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Whoop
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret

# Twitch
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# --- Optional Services ---

# Redis (falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379

# PostHog analytics
# VITE_POSTHOG_KEY=phc_your-posthog-key
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error tracking
# VITE_SENTRY_DSN=https://your-sentry-dsn

# Enrichment APIs
# SCRAPIN_API_KEY=your-scrapin-key
# PDL_API_KEY=your-pdl-key

# Cron job authentication
# CRON_SECRET=your-cron-secret
