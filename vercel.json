{
  "version": 2,
  "buildCommand": "npm run build",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://us-assets.i.posthog.com https://us.i.posthog.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://openrouter.ai https://*.supabase.co wss://*.supabase.co https://us.i.posthog.com https://us-assets.i.posthog.com; frame-src 'self' https://accounts.google.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
        },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(self), camera=(), microphone=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/icons/3d/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000" }
      ]
    },
    {
      "source": "/:path*.woff2",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.woff",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.ttf",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.otf",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/:path*.eot",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/webhook-pluggy.js": {
      "maxDuration": 60
    },
    "api/webhook-truelayer.js": {
      "maxDuration": 60
    },
    "api/webhook-plaid.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/webhooks/pluggy",
      "dest": "/api/webhook-pluggy.js"
    },
    {
      "src": "/api/webhooks/truelayer",
      "dest": "/api/webhook-truelayer.js"
    },
    {
      "src": "/api/webhooks/plaid",
      "dest": "/api/webhook-plaid.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|json|webmanifest|webp|avif))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/ingest-observations",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/memory-archive",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/soul-signature-regen",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/memory-forgetting",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/email-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/memory-saliency-replay",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/prospective-check",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/meeting-prep",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/meeting-debrief",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/stripe-webhook-events-cleanup",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/wiki-compile",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/health-monitor",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/deliver-insights",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/morning-briefing",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/inbox-intelligence",
      "schedule": "5 10 * * *"
    },
    {
      "path": "/api/cron/relationships",
      "schedule": "10 10 * * *"
    },
    {
      "path": "/api/cron/morning-briefing-email",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/intelligent-triggers",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/action-reflection",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/pluggy-sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/plaid-sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/statement-nag",
      "schedule": "0 12 1 * *"
    },
    {
      "path": "/api/cron/bank-consent",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/investment-correlation",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/twin-summary-refresh",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/calendar-optimization",
      "schedule": "0 8 * * 1-5"
    },
    {
      "path": "/api/cron/nudge-inactive",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/department-execute",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/agent-actions-cleanup",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/outcome-learning",
      "schedule": "30 3 * * *"
    },
    {
      "path": "/api/cron/twin-self-improvement",
      "schedule": "0 4 * * *"
    }
  ]
}
