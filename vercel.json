{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.js": {
      "maxDuration": 120
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot))",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/platform-polling",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/pattern-learning",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/ingest-observations",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/claude-sync",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/claude-sync/process-analysis",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/memory-archive",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/memory-forgetting",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/email-digest",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/memory-saliency-replay",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/personality-eval",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/prospective-check",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/evening-recap",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/deliver-insights",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/morning-briefing",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/morning-briefing-email",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/intelligent-triggers",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/action-reflection",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/personality-validation",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/calendar-optimization",
      "schedule": "0 8 * * 1-5"
    }
  ]
}
