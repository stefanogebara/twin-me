{
  "manifest_version": 3,
  "name": "Soul Signature - Digital Twin Collector",
  "version": "2.0.0",
  "description": "Capture your digital footprint from streaming platforms to build your authentic Soul Signature profile",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "history",
    "alarms"
  ],
  "homepage_url": "https://twin-ai-learn.vercel.app",
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://www.twitch.tv/*",
    "https://www.netflix.com/*",
    "https://www.hulu.com/*",
    "https://www.hbomax.com/*",
    "https://max.com/*",
    "https://www.primevideo.com/*",
    "https://www.amazon.com/gp/video/*",
    "https://www.disneyplus.com/*",
    "https://twin-ai-learn.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["collectors/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["collectors/twitch.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["collectors/netflix.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.hulu.com/*"],
      "js": ["collectors/hulu.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.hbomax.com/*", "https://max.com/*"],
      "js": ["collectors/hbomax.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.primevideo.com/*", "https://www.amazon.com/gp/video/*"],
      "js": ["collectors/primevideo.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.disneyplus.com/*"],
      "js": ["collectors/disneyplus.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content/*"],
      "matches": [
        "https://www.youtube.com/*",
        "https://www.twitch.tv/*",
        "https://www.netflix.com/*",
        "https://twin-ai-learn.vercel.app/*"
      ]
    }
  ]
}
