{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TwinMe",
  "version": "0.2.2",
  "identifier": "ai.twinme.desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../www"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "TwinMe",
        "width": 1280,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "center": true,
        "visible": true,
        "skipTaskbar": false,
        "titleBarStyle": "Visible"
      },
      {
        "label": "hummingbird",
        "title": "TwinMe Quick Panel",
        "url": "https://twinme.me/widget?panel=1",
        "width": 460,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "shadow": false
      },
      {
        "label": "settings",
        "title": "TwinMe Settings",
        "url": "settings.html",
        "width": 720,
        "height": 560,
        "minWidth": 560,
        "minHeight": 440,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "tooltip": "TwinMe"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "publisher": "TwinMe",
    "category": "Productivity",
    "shortDescription": "Your AI twin, always one keystroke away.",
    "longDescription": "TwinMe Desktop is a native home for your Soul Signature: a guided first-run that explains on-device meeting notes, context awareness, and the global hotkey (Cmd+Shift+T), plus a system tray and native notifications. Inspired by Littlebird and jo.",
    "copyright": "Copyright © 2026 TwinMe",
    "createUpdaterArtifacts": false,
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "twinme.me"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["twinme"]
      }
    }
  }
}
