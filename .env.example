# ===========================================
# TwinMe - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Core ---
NODE_ENV=development
PORT=3004
VITE_APP_URL=http://localhost:8086
VITE_API_URL=http://localhost:3004/api

# --- Supabase (PostgreSQL + pgvector) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Auth ---
JWT_SECRET=generate-a-strong-random-string-min-32-chars
ENCRYPTION_KEY=generate-a-strong-random-string-min-32-chars

# --- AI / LLM ---
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# Optional: daily budget cap in USD (default: 10)
# LLM_DAILY_BUDGET_USD=10

# --- Platform Integrations (Active) ---

# Spotify
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Google (Calendar + YouTube)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Whoop
WHOOP_CLIENT_ID=your-whoop-client-id
WHOOP_CLIENT_SECRET=your-whoop-client-secret

# Twitch
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# --- Optional Services ---

# Redis (falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379

# PostHog analytics
# VITE_POSTHOG_KEY=phc_your-posthog-key
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error tracking
# VITE_SENTRY_DSN=https://your-sentry-dsn

# Enrichment APIs
# SCRAPIN_API_KEY=your-scrapin-key
# PDL_API_KEY=your-pdl-key

# Browser Extension CORS
# Comma-separated list of allowed browser extension IDs (e.g., "abcd1234efgh5678,ijkl9012mnop3456")
# Leave empty in development to allow all extensions; must be set in production
# ALLOWED_EXTENSION_IDS=

# Chrome Extension ID used to sync auth tokens from OAuthCallback
VITE_CHROME_EXTENSION_ID=acnofcjjfjaikcfnalggkkbghjaijepc

# Cron job authentication
# CRON_SECRET=your-cron-secret
# WARNING: SKIP_CRON_AUTH=true disables cron authentication entirely — NEVER set this in production

# Stripe billing
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price-id
STRIPE_MAX_PRICE_ID=price_your-max-price-id
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key

# Resend email
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=twin@twinme.me

# Notion OAuth
# Create an integration at https://www.notion.so/my-integrations (public integration,
# redirect URI: <your-app-url>/oauth/callback). Tokens do not expire and are not refreshable.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Pinterest OAuth (API v5)
# Create an app at https://developers.pinterest.com/apps/ (self-serve, no approval queue).
# Redirect URI: <your-app-url>/oauth/callback. Access tokens last ~30 days; refresh tokens ~365 days.
# Set PINTEREST_USE_PRODUCTION=true to hit the production API instead of the sandbox.
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
# PINTEREST_USE_PRODUCTION=false

# SoundCloud OAuth (API v2, OAuth 2.1 + PKCE)
# Developer key issuance is currently CLOSED by SoundCloud (since 2023) — join the queue at
# https://developers.soundcloud.com/docs/api/guide. Leave blank to have /connect/soundcloud
# return a graceful 503 `not_configured` response. Redirect URI: <your-app-url>/oauth/callback.
# Access tokens live ~1h; refresh_token rotates on each refresh.
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=

# Steam Web API
# Get a key at https://steamcommunity.com/dev/apikey (instant, free, no approval).
# Used for public profile / owned games / playtime / achievements. No OAuth —
# the user supplies their Steam profile URL or 64-bit Steam ID via the Connect modal.
STEAM_WEB_API_KEY=
